# Database
DATABASE_URL="postgresql://user:password@localhost:5432/realestate"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# VOW API (PROPTX)
VOW_API_URL="https://api.proptx.com/vow"
VOW_API_KEY="your-vow-api-key"
VOW_CLIENT_ID="your-client-id"
VOW_CLIENT_SECRET="your-client-secret"

# Mapbox (for maps)
NEXT_PUBLIC_MAPBOX_TOKEN="your-mapbox-token"

# Ampre API (https://developer.ampre.ca/docs/getting-started)
AMPRE_API_URL="https://query.ampre.ca/odata"
AMPRE_ACCESS_TOKEN="your-ampre-access-token"
